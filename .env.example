# RimRevive Environment Variables Template
# Copy this file to .env.local for development or .env.production for production

# ========================================
# Twilio WhatsApp Configuration
# ========================================

# Your Twilio Account SID (from Twilio Console)
TWILIO_ACCOUNT_SID=your_account_sid_here

# Your Twilio Auth Token (from Twilio Console)
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp-enabled phone number (E.164 format)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Business owner's phone number for notifications (E.164 format)
TWILIO_TO_NUMBER=+16041234567

# ========================================
# Application Configuration
# ========================================

# Node.js environment (development, production, test)
NODE_ENV=development

# Public URL of your application (used for absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number displayed to users
NEXT_PUBLIC_WHATSAPP_NUMBER=+16041234567

# Internal application URL (used in WhatsApp messages)
APP_URL=http://localhost:3000

# ========================================
# Feature Flags
# ========================================

# Enable WhatsApp simulation mode (logs to console instead of sending)
WHATSAPP_SIMULATE=true

# Enable admin dashboard (future feature)
ENABLE_ADMIN_DASHBOARD=false

# ========================================
# Deployment Configuration
# ========================================

# Port for Next.js application
PORT=3000

# Hostname to bind to (use 0.0.0.0 for Docker)
HOSTNAME=0.0.0.0

# Database file path (automatically set based on NODE_ENV)
# DB_PATH=./rimrevive.json

# ========================================
# Development Notes
# ========================================

# For development with WhatsApp simulation:
# 1. Set WHATSAPP_SIMULATE=true
# 2. Twilio credentials can be dummy values
# 3. WhatsApp messages will be logged to console

# For production:
# 1. Set NODE_ENV=production
# 2. Set WHATSAPP_SIMULATE=false
# 3. Use real Twilio credentials
# 4. Use HTTPS URLs
# 5. Database will be stored at /data/rimrevive.json

# Security Warning:
# - Never commit .env files to version control
# - Keep TWILIO_AUTH_TOKEN secret
# - Use environment-specific files (.env.local, .env.production)